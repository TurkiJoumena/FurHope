{% extends 'base.html.twig' %}

{% block title %}Planning - Vétérinaire{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/dashboard-theme.css') }}">
    <style>
        .planning-layout {
            display: grid;
            grid-template-columns: 2.2fr 1fr;
            gap: 28px;
            align-items: start;
            width: 100%;
        }
        @media (max-width: 1100px) {
            .planning-layout { grid-template-columns: 1fr; }
        }
        .form-group { display: grid; gap: 6px; margin-bottom: 20px; width: 100%; }
        .form-group label { font-weight: 700; font-size: 0.95rem; }
        .form-group input, .form-group select, .form-group textarea {
            padding: 12px 14px; border-radius: 12px; border: 1px solid rgba(27,27,24,0.16); background: rgba(255,255,255,0.9); width: 100%; max-width: 100%; box-sizing: border-box;
        }
        .field-error { color: #8f2e2e; font-size: 0.85rem; margin-top: 4px; }
        
        .fc-event { cursor: pointer; border-radius: 4px; }
        .fc-toolbar-title { font-family: Georgia, serif; font-size: 1.4rem !important; }
        .fc .fc-button-primary { background: rgba(255,255,255,0.6) !important; color: var(--ink) !important; border-color: rgba(27,27,24,0.18) !important; }
        .fc .fc-button-primary:hover { background: rgba(255,255,255,0.9) !important; }
        .fc .fc-button-active { background: var(--accent) !important; color: white !important; border-color: var(--accent) !important; }
        
        .ops-card__header { padding-bottom: 16px; border-bottom: 1px solid rgba(27,27,24,0.08); margin-bottom: 16px; }
    </style>
{% endblock %}

{% block body %}
    <div class="ops-shell" style="grid-template-columns: 1fr;">

        <main class="ops-main">
            <section class="ops-topbar" style="margin-bottom: 24px; text-align: left; justify-items: flex-start;">
                <div class="ops-topbar__intro" style="justify-items: flex-start;">
                    <h1 style="font-size: 2.8rem; margin-bottom: 0;">Planning professionnel</h1>
                    <p style="margin-top: 6px;">Planifiez vos événements, séminaires, et visualisez vos rendez-vous confirmés.</p>
                </div>
            </section>

            <div class="alert-wrap" style="padding: 0;">
                {% for message in app.flashes('success') %}
                    <div class="flash flash-success" style="margin-bottom: 20px;">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('danger') %}
                    <div class="flash flash-error" style="margin-bottom: 20px;">{{ message }}</div>
                {% endfor %}
            </div>

            <div class="planning-layout">
                <!-- CALENDRIER -->
                <article class="ops-card" style="padding: 24px; background: rgba(255, 255, 255, 0.72); width: 100%;">
                    <div id="calendar-holder" style="min-height: 700px;"></div>
                </article>

                <!-- SIDEBAR -->
                <aside style="display: flex; flex-direction: column; gap: 24px; width: 100%;">
                    <!-- FORMULAIRE -->
                    <article class="ops-card" style="padding: 24px; width: 100%; box-sizing: border-box;">
                        <div class="ops-card__header">
                            <h2 style="font-size: 1.4rem; margin: 0;">Nouvel événement</h2>
                        </div>
                        <div style="width: 100%;">
                            {{ form_start(form) }}
                                <div class="form-group">
                                    {{ form_label(form.title) }}
                                    {{ form_widget(form.title) }}
                                    <div class="field-error">{{ form_errors(form.title) }}</div>
                                </div>
                                <div class="form-group">
                                    {{ form_label(form.eventType) }}
                                    {{ form_widget(form.eventType) }}
                                    <div class="field-error">{{ form_errors(form.eventType) }}</div>
                                </div>
                                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                                    <div class="form-group">
                                        {{ form_label(form.startsAt) }}
                                        {{ form_widget(form.startsAt) }}
                                        <div class="field-error">{{ form_errors(form.startsAt) }}</div>
                                    </div>
                                    <div class="form-group">
                                        {{ form_label(form.endsAt) }}
                                        {{ form_widget(form.endsAt) }}
                                        <div class="field-error">{{ form_errors(form.endsAt) }}</div>
                                    </div>
                                </div>
                                <div class="form-group">
                                    {{ form_label(form.description) }}
                                    {{ form_widget(form.description, {'attr': {'rows': 3}}) }}
                                    <div class="field-error">{{ form_errors(form.description) }}</div>
                                </div>
                                
                                <div style="margin-top: 24px; text-align: center;">
                                    {{ form_widget(form.save, {'attr': {'class': 'button button-primary', 'style': 'border-radius: 999px; padding: 12px 32px; font-weight: 700;'}}) }}
                                </div>
                            {{ form_end(form) }}
                        </div>
                    </article>

                    <!-- LISTE -->
                    <article class="ops-card ops-card--table">
                        <div class="ops-card__header" style="margin: 24px 24px 12px 24px;">
                            <h2 style="font-size: 1.4rem; margin: 0;">Événements personnels</h2>
                        </div>
                        <div class="ops-list">
                            {% for event in planningEvents %}
                                <div class="ops-list__item" style="padding: 16px 24px; display: flex; justify-content: space-between; align-items: flex-start; gap: 12px;">
                                    <div style="line-height: 1.4;">
                                        <strong style="display:block; font-size: 1.1rem; color: var(--ink);">{{ event.title }}</strong>
                                        <span style="font-size: 0.85rem; color: var(--accent); font-weight: 700; text-transform: uppercase;">{{ event.eventType }}</span>
                                        <div style="font-size: 0.85rem; color: var(--muted); margin-top: 4px;">
                                            {{ event.startsAt|date('d/m/y H:i') }}
                                            {% if event.endsAt %} - {{ event.endsAt|date('d/m/y H:i') }}{% endif %}
                                        </div>
                                    </div>
                                    <form method="post" action="{{ path('vet_calendar_delete', {id: event.id}) }}">
                                        <button class="ops-button ops-button--ghost" style="padding: 4px 10px; font-size: 0.8rem; border-color: #d1b5b5; color: #a34e4e;" onclick="return confirm('Confirmer la suppression ?')">Supprimer</button>
                                    </form>
                                </div>
                            {% else %}
                                <div class="ops-list__item ops-list__item--empty" style="padding: 24px;">
                                    <div>
                                        <strong>Agenda vide</strong>
                                        <span>Aucun événement personnel enregistré.</span>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    </article>
                </aside>
            </div>
        </main>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const calendarEl = document.getElementById('calendar-holder');
            if (!calendarEl) return;

            const calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'dayGridMonth',
                locale: 'fr',
                height: 'auto',
                headerToolbar: {
                    start: 'prev,next today',
                    center: 'title',
                    end: 'dayGridMonth,timeGridWeek,timeGridDay'
                },
                buttonText: {
                    today: "Aujourd'hui",
                    month: "Mois",
                    week: "Semaine",
                    day: "Jour"
                },
                eventSources: [{
                    url: '{{ path('fc_load_events') }}',
                    method: 'POST',
                    extraParams: {
                        filters: JSON.stringify({})
                    },
                    failure: function () {
                        console.error("Le rendu du calendrier a échoué côté serveur.");
                    }
                }],
                eventClick: function (info) {
                    const desc = info.event.extendedProps.description ? ('\\n\\nNotes: ' + info.event.extendedProps.description) : '';
                    alert('🏷️ ' + info.event.title + desc);
                }
            });

            calendar.render();
        });
    </script>
{% endblock %}
