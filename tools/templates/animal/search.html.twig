{% extends 'base.html.twig' %}

{% block title %}Animal Search - {{ animalName|default('Animal') }} | FurHope{% endblock %}

{% block body %}
<section class="animal-search-page" style="max-width: 1000px; margin: 0 auto; padding: 2rem 1rem;">
    <div class="search-header" style="text-align: center; margin-bottom: 3rem;">
        <h1>Animal Encyclopedia</h1>
        <p class="lead" style="color: #666; font-size: 1.2rem;">Discover detailed information about your favorite animals from Wikipedia</p>
        
        <form method="GET" action="{{ path('app_animal_search') }}" style="margin-top: 2rem; max-width: 600px; margin-left: auto; margin-right: auto;">
            <div class="input-group" style="display: flex; gap: 1rem;">
                <input type="search" 
                       name="q" 
                       value="{{ animalName }}" 
                       placeholder="Search for an animal (e.g., dog, cat, elephant...)" 
                       class="form-control" 
                       style="flex: 1; padding: 1rem 1.5rem; font-size: 1.1rem; border: 2px solid #e0e0e0; border-radius: 50px; outline: none;"
                       required>
                <button type="submit" class="button-primary" style="padding: 1rem 2.5rem; font-size: 1.1rem; border-radius: 50px; min-width: 140px;">
                    🐾 Search
                </button>
            </div>
        </form>
    </div>

    {% if animalName %}
        {% if wiki %}
            <article class="animal-shop__wiki-result" style="margin-top: 48px; padding: 32px; background: rgba(255,255,255,0.8); border-radius: 24px; border: 1px solid rgba(27,27,24,0.08); box-shadow: 0 20px 60px rgba(0,0,0,0.1);">
                {% if wiki.thumbnail %}
                    <img src="{{ wiki.thumbnail.source }}" alt="{{ wiki.title }}" style="width: 100%; max-width: 320px; height: auto; border-radius: 20px; margin-bottom: 24px; display: block; margin-left: auto; margin-right: auto;">
                {% endif %}
                <h2 style="text-align: center; margin-bottom: 20px; color: #2d3748; font-size: 2.2rem;">{{ wiki.title }}</h2>
                <div style="line-height: 1.7; font-size: 1.05rem; max-width: 800px; margin: 0 auto; color: #4a5568;">
                    {{ wiki.extract|raw }}
                </div>
                <div style="margin-top: 2rem; text-align: center;">
                    <a href="https://en.wikipedia.org/wiki/{{ animalName|url_encode }}" target="_blank" class="button-primary" style="padding: 12px 32px; font-size: 1.1rem;">
                        🐾 Read more on Wikipedia
                    </a>
                </div>
            </article>
            <style>
                @keyframes fadeInUp {
                    from { opacity: 0; transform: translateY(30px); }
                    to { opacity: 1; transform: translateY(0); }
                }
                .animal-shop__wiki-result {
                    animation: fadeInUp 0.6s ease-out;
                }
            </style>
        {% elseif error %}
            <div class="alert alert-warning" style="padding: 2rem; border-radius: 16px; background: #fff3cd; border: 1px solid #ffeaa7; margin-top: 2rem;">
                <h3 style="margin-bottom: 1rem; color: #856404;">{{ error }}</h3>
                <p style="margin: 0; color: #856404;">Try searching for a different animal name.</p>
            </div>
        {% endif %}
    {% endif %}

    <div style="text-align: center; margin-top: 4rem; padding-top: 2rem; border-top: 1px solid #e2e8f0;">
        <a href="{{ path('animal_shop_index') }}" class="button-secondary" style="padding: 12px 24px;">
            ← Back to Animal Shop
        </a>
    </div>
</section>
{% endblock %}

