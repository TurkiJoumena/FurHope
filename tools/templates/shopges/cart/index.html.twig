{% extends 'base.html.twig' %}

{% block title %}Cart{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/shopges/shop.css') }}">
    <style>
        .flash {
            opacity: 1;
            transition: opacity 0.18s ease;
        }

        .flash.is-dismissing {
            opacity: 0;
        }
    </style>
{% endblock %}

{% block body %}
    <section class="panel">
        <div class="section-heading">
            <div>
                <h1>Your shopping cart</h1>
            </div>
            <a class="button secondary" href="{{ path('app_shop') }}">Continue shopping</a>
        </div>
    </section>

    <section class="cart-layout">
        <div class="cart-stack">
            {% for item in cart_items %}
                <article class="cart-card">
                    <div class="cart-card__media">
                        {% if item.produit.image and (item.produit.image starts with 'uploads/' or item.produit.image starts with 'http') %}
                            <img src="{% if item.produit.image starts with 'http' %}{{ item.produit.image }}{% else %}/{{ item.produit.image }}{% endif %}" alt="{{ item.title }}">
                        {% endif %}
                    </div>

                    <div class="cart-card__body">
                        <div class="cart-card__top">
                            <div>
                                <span class="badge">{{ item.produit.categoryLabel }}</span>
                                <h3 class="wrap">{{ item.title }}</h3>
                            </div>

                            <form method="post" action="{{ path('app_cart_remove', {id: item.id}) }}">
                                <button class="button danger" type="submit">Remove</button>
                            </form>
                        </div>

                        <div class="cart-card__meta">
                            <div>
                                <span>Price</span>
                                <strong>{{ cart_item_totals_converted[item.id]|default(0)|number_format(2, '.', ' ') }} {{ payment_currency.code }}</strong>
                                <small class="muted">{{ item.lineTotal|number_format(2, '.', ' ') }} TND</small>
                            </div>
                            <div>
                                <span>Stock available</span>
                                <strong class="{% if item.produit.stock <= 3 %}stock-low{% endif %}">{{ item.produit.stock }}</strong>
                            </div>
                            <div>
                                <span>Quantity</span>
                                <strong>{{ item.qty }}</strong>
                            </div>
                        </div>

                        <div class="cart-card__bottom">
                            <form method="post" action="{{ path('app_cart_update', {id: item.id}) }}" class="actions cart-auto-update">
                                <div class="field cart-qty">
                                    <label for="qty_{{ item.id }}">Quantity</label>
                                    <input id="qty_{{ item.id }}" type="number" name="qty" min="0" max="{{ item.produit.stock }}" value="{{ item.qty }}">
                                </div>
                            </form>

                            <div class="price-row">
                                <div>
                                    <small>Total after TVA</small>
                                    <strong>{{ cart_item_totals_converted[item.id]|default(0)|number_format(2, '.', ' ') }} {{ payment_currency.code }}</strong>
                                    <small class="muted">{{ item.lineTotal|number_format(2, '.', ' ') }} TND</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </article>
            {% else %}
                <article class="empty-state">
                    <h2>Your cart is empty</h2>
                    <p>Add products from the shop and they will appear here instantly.</p>
                </article>
            {% endfor %}
        </div>

        <aside class="cart-summary">
            <div class="cart-summary__header">
                <h2>Your cart</h2>
                <span class="badge">{{ cart_quantity }} items</span>
            </div>

            <div class="cart-summary__rows">
                <div class="summary-row">
                    <span>Items</span>
                    <strong>{{ cart_quantity }}</strong>
                </div>
                <div class="summary-row">
                    <span>Payment currency</span>
                    <strong>{{ payment_currency.code }}</strong>
                </div>
                <div class="summary-row">
                    <span>Subtotal</span>
                    <strong>{{ cart_subtotal_converted|number_format(2, '.', ' ') }} {{ payment_currency.code }}</strong>
                </div>
                {% if applied_promo %}
                    <div class="summary-row">
                        <span>Promo {{ applied_promo.code }} ({{ cart_discount_percentage|number_format(1, '.', ' ') }}%)</span>
                        <strong>-{{ cart_discount_amount_converted|number_format(2, '.', ' ') }} {{ payment_currency.code }}</strong>
                    </div>
                {% endif %}
                <div class="summary-row total">
                    <span>Total</span>
                    <strong>{{ cart_total_converted|number_format(2, '.', ' ') }} {{ payment_currency.code }}</strong>
                </div>
            </div>

            <div class="panel cart-currency-panel" style="padding: 18px; margin-bottom: 18px;">
                <form method="post" action="{{ path('app_cart_currency') }}" class="field">
                    <label for="payment-currency">Convert payment currency</label>
                    <select id="payment-currency" name="currency">
                        {% for code, details in available_currencies %}
                            <option value="{{ code }}" {% if payment_currency.code == code %}selected{% endif %}>{{ code }} - {{ details.label }}</option>
                        {% endfor %}
                    </select>
                    <small class="muted">Base catalog prices stay stored in TND. Stripe checkout uses the selected currency.</small>
                    <div class="actions">
                        <button class="button secondary" type="submit">Update currency</button>
                    </div>
                </form>
            </div>

            <div class="panel" style="padding: 18px; margin-bottom: 18px;">
                <form method="post" action="{{ path('app_cart_promo_apply') }}" class="field">
                    <label for="promo-code">Promo code</label>
                    <input id="promo-code" type="text" name="code" value="{{ applied_promo ? applied_promo.code : '' }}" placeholder="Enter your promo code">
                    <div class="actions">
                        <button class="button secondary" type="submit">Apply code</button>
                    </div>
                </form>
                {% if applied_promo %}
                    <form method="post" action="{{ path('app_cart_promo_remove') }}" class="actions" style="margin-top: 10px;">
                        <button class="button danger" type="submit">Remove code</button>
                    </form>
                {% endif %}
            </div>

            <div class="actions" style="justify-content: center;">
                <form method="post" action="{{ path('app_shop_checkout_start') }}">
                    <button class="button" type="submit" {% if cart_quantity <= 0 %}disabled{% endif %}>Proceed to payment</button>
                </form>
            </div>
        </aside>
    </section>

    <script>
        (function () {
            const flashes = document.querySelectorAll('.flash-list .flash');
            if (flashes.length > 0) {
                window.setTimeout(function () {
                    flashes.forEach(function (flash) {
                        flash.classList.add('is-dismissing');
                    });

                    window.setTimeout(function () {
                        flashes.forEach(function (flash) {
                            flash.remove();
                        });
                    }, 180);
                }, 500);
            }

            const forms = document.querySelectorAll('.cart-auto-update');
            forms.forEach(function (form) {
                const input = form.querySelector('input[name="qty"]');
                if (!input) {
                    return;
                }

                let timeoutId = null;
                let submitted = false;
                const submit = function () {
                    if (submitted) {
                        return;
                    }

                    submitted = true;
                    input.readOnly = true;
                    form.requestSubmit();
                };

                input.addEventListener('input', function () {
                    window.clearTimeout(timeoutId);
                    submitted = false;
                    input.readOnly = false;
                    timeoutId = window.setTimeout(submit, 250);
                });
            });
        })();
    </script>
{% endblock %}

