{% extends 'base.html.twig' %}

{% block title %}{{ 'auth.register.title'|trans }}{% endblock %}

{% block body %}
    <div class="auth-wrap">
        <section class="panel form-card auth-card">
            <div class="eyebrow">{{ 'auth.register.eyebrow'|trans }}</div>
            <h1 style="font-size: 2.8rem;">{{ 'auth.register.heading'|trans }}</h1>
            <p class="muted">{{ 'auth.register.subtitle'|trans }}</p>

            {{ form_start(registrationForm, { attr: { class: 'auth-form', novalidate: 'novalidate' } }) }}
                <div class="form-group">
                    {{ form_label(registrationForm.firstName) }}
                    {{ form_widget(registrationForm.firstName, {
                        attr: {
                            placeholder: 'auth.placeholders.first_name'|trans,
                            autocomplete: 'given-name'
                        }
                    }) }}
                    {{ form_errors(registrationForm.firstName) }}
                </div>

                <div class="form-group">
                    {{ form_label(registrationForm.lastName) }}
                    {{ form_widget(registrationForm.lastName, {
                        attr: {
                            placeholder: 'auth.placeholders.last_name'|trans,
                            autocomplete: 'family-name'
                        }
                    }) }}
                    {{ form_errors(registrationForm.lastName) }}
                </div>

                <div class="form-group">
                    {{ form_label(registrationForm.email) }}
                    {{ form_widget(registrationForm.email, {
                        attr: {
                            placeholder: 'auth.placeholders.email'|trans,
                            autocomplete: 'email',
                            inputmode: 'email'
                        }
                    }) }}
                    <p class="form-help">{{ 'auth.register.email_help'|trans }}</p>
                    {{ form_errors(registrationForm.email) }}
                </div>

                <div class="form-group">
                    {{ form_label(registrationForm.phoneNumber) }}
                    {{ form_widget(registrationForm.phoneNumber, {
                        attr: {
                            placeholder: 'auth.placeholders.phone'|trans,
                            autocomplete: 'tel',
                            inputmode: 'tel'
                        }
                    }) }}
                    <p class="form-help">{{ 'auth.register.phone_help'|trans }}</p>
                    {{ form_errors(registrationForm.phoneNumber) }}
                </div>

                <div class="form-group">
                    <div class="checkbox-row">
                        {{ form_widget(registrationForm.isVeteranApplicant) }}
                        {{ form_label(registrationForm.isVeteranApplicant) }}
                    </div>
                    {{ form_errors(registrationForm.isVeteranApplicant) }}
                </div>

                <div class="form-group">
                    {{ form_label(registrationForm.plainPassword.first) }}
                    {{ form_widget(registrationForm.plainPassword.first, {
                        attr: {
                            placeholder: 'auth.placeholders.password_min'|trans,
                            autocomplete: 'new-password'
                        }
                    }) }}
                    <p class="form-help">{{ 'auth.register.password_help'|trans }}</p>
                    {{ form_errors(registrationForm.plainPassword.first) }}
                </div>

                <div class="form-group">
                    {{ form_label(registrationForm.plainPassword.second) }}
                    {{ form_widget(registrationForm.plainPassword.second, {
                        attr: {
                            placeholder: 'auth.placeholders.repeat_password'|trans,
                            autocomplete: 'new-password'
                        }
                    }) }}
                    {{ form_errors(registrationForm.plainPassword.second) }}
                </div>

                <div class="form-group">
                    <div class="checkbox-row">
                        {{ form_widget(registrationForm.agreeTerms) }}
                        {{ form_label(registrationForm.agreeTerms, 'auth.register.agree_terms'|trans) }}
                    </div>
                    {{ form_errors(registrationForm.agreeTerms) }}
                </div>

                {{ form_rest(registrationForm) }}
                <button class="button-primary" type="submit">{{ 'auth.actions.create_account'|trans }}</button>
            {{ form_end(registrationForm) }}
        </section>
    </div>
{% endblock %}
