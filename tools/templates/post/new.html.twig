{% extends 'base.html.twig' %}

{% block title %}{{ 'feed_page.new.title'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/social-feed.css') }}">
{% endblock %}

{% block body %}
    <section class="social-detail social-detail--narrow">
        <div class="social-detail__main">
            <section class="social-panel social-panel--hero">
                <div class="social-panel__head">
                    <div>
                        <p class="social-kicker">{{ 'feed_page.new.kicker'|trans }}</p>
                        <h1>{{ 'feed_page.new.heading'|trans }}</h1>
                        <p>{{ 'feed_page.new.text'|trans }}</p>
                    </div>
                </div>
            </section>

            {{ include('post/_form.html.twig', {
                form: form,
                submit_label: 'feed_page.actions.publish_post',
                cancel_path: path('feed_index')
            }) }}
        </div>
    </section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        window.addEventListener('DOMContentLoaded', () => {
            {{ include('post/_ai_caption_script.html.twig') }}
        });
    </script>
{% endblock %}
