<!DOCTYPE html>
<html lang="{{ app.request.locale|default('en') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Animal Search - {{ animalName|default('Animal') }} | FurHope</title>
    <style>
        :root { --canvas: #f7f1e3; --ink: #1b1b18; --muted: #6e655d; --accent: #cf6a32; --line: rgba(27, 27, 24, 0.10); }
        * { box-sizing: border-box; }
        body { margin: 0; min-height: 100vh; font-family: Georgia, "Times New Roman", serif; color: var(--ink); background: linear-gradient(180deg, var(--canvas), #f4ede0); }
        a { color: inherit; text-decoration: none; }
        .topbar { border-bottom: 1px solid var(--line); background: rgba(247, 241, 227, 0.92); }
        .shell { width: min(1000px, calc(100% - 32px)); margin: 0 auto; }
        .topbar__inner { min-height: 72px; display: flex; align-items: center; justify-content: space-between; gap: 16px; }
        .brand, .actions { display: inline-flex; align-items: center; gap: 10px; flex-wrap: wrap; }
        .brand__mark { width: 42px; height: 42px; display: grid; place-items: center; border-radius: 14px; background: var(--accent); color: #fff; }
        .button-primary, .button-secondary { display: inline-flex; align-items: center; justify-content: center; border-radius: 999px; padding: 12px 22px; border: 1px solid transparent; font: inherit; cursor: pointer; }
        .button-primary { background: var(--accent); color: #fff; }
        .button-secondary { background: rgba(255, 255, 255, 0.78); border-color: var(--line); }
        .animal-search-page { padding: 2rem 0 4rem; }
        .search-header { text-align: center; margin-bottom: 3rem; }
        .lead { color: var(--muted); font-size: 1.2rem; }
        .search-form { margin: 2rem auto 0; max-width: 640px; }
        .input-group { display: flex; gap: 1rem; }
        input[type="search"] { flex: 1; min-width: 0; padding: 1rem 1.5rem; font: inherit; font-size: 1.1rem; border: 2px solid #e0d7c9; border-radius: 999px; outline: 0; background: rgba(255, 255, 255, 0.86); }
        .wiki-result { margin-top: 48px; padding: 32px; background: rgba(255,255,255,0.8); border-radius: 24px; border: 1px solid rgba(27,27,24,0.08); box-shadow: 0 20px 60px rgba(0,0,0,0.1); }
        .wiki-result img { width: 100%; max-width: 320px; height: auto; border-radius: 20px; margin: 0 auto 24px; display: block; }
        .wiki-result h2 { text-align: center; margin-bottom: 20px; color: #2d3748; font-size: 2.2rem; }
        .wiki-copy { line-height: 1.7; font-size: 1.05rem; max-width: 800px; margin: 0 auto; color: #4a5568; }
        .alert { padding: 2rem; border-radius: 16px; background: #fff3cd; border: 1px solid #ffeaa7; margin-top: 2rem; color: #856404; }
        .footer-actions { text-align: center; margin-top: 4rem; padding-top: 2rem; border-top: 1px solid #e2d8c8; }
        @media (max-width: 700px) { .input-group, .topbar__inner { flex-direction: column; align-items: stretch; } .button-primary, .button-secondary { width: 100%; } }
    </style>
</head>
<body>
<header class="topbar">
    <div class="shell topbar__inner">
        <a class="brand" href="{{ path('app_home') }}">
            <span class="brand__mark">&#128062;</span>
            <strong>FurHope</strong>
        </a>
        <div class="actions">
            <a class="button-secondary" href="{{ path('animal_shop_index') }}">Animal Shop</a>
            <a class="button-secondary" href="{{ path('app_home') }}">Home</a>
        </div>
    </div>
</header>

<main class="shell animal-search-page">
    <div class="search-header">
        <h1>Animal Encyclopedia</h1>
        <p class="lead">Discover detailed information about your favorite animals from Wikipedia</p>

        <form class="search-form" method="GET" action="{{ path('app_animal_search') }}">
            <div class="input-group">
                <input type="search"
                       name="q"
                       value="{{ animalName }}"
                       placeholder="Search for an animal (e.g., dog, cat, elephant...)"
                       required>
                <button type="submit" class="button-primary">Search</button>
            </div>
        </form>
    </div>

    {% if animalName %}
        {% if wiki %}
            <article class="wiki-result">
                {% if wiki.thumbnail %}
                    <img src="{{ wiki.thumbnail.source }}" alt="{{ wiki.title }}">
                {% endif %}
                <h2>{{ wiki.title }}</h2>
                <div class="wiki-copy">
                    {{ wiki.extract }}
                </div>
                <div class="footer-actions">
                    <a href="https://en.wikipedia.org/wiki/{{ animalName|url_encode }}" target="_blank" rel="noopener" class="button-primary">Read more on Wikipedia</a>
                </div>
            </article>
        {% elseif error %}
            <div class="alert">
                <h3>{{ error }}</h3>
                <p>Try searching for a different animal name.</p>
            </div>
        {% endif %}
    {% endif %}

    <div class="footer-actions">
        <a href="{{ path('animal_shop_index') }}" class="button-secondary">Back to Animal Shop</a>
    </div>
</main>
</body>
</html>
