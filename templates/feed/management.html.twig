{% extends 'base.html.twig' %}

{% block title %}Social Management{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/social-feed.css') }}">
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>
    <script type="text/javascript">
        {{ gc_draw([dailyEngagementChart, engagementBreakdownChart], ['social_daily_engagement_chart', 'social_engagement_breakdown_chart']) }}
    </script>
{% endblock %}

{% block body %}
    <div class="social-page social-page--management">
        <section class="social-hero-card">
            <div>
                <p class="social-kicker">Dashboard social</p>
                <h1>Social management</h1>
                <p>Review your posts and track how likes, dislikes, and shares change each day.</p>
            </div>
            <div class="social-inline-actions">
                <a class="button-primary" href="{{ path('post_new') }}">Create post</a>
                <a class="button-secondary" href="{{ path('feed_index') }}">Open social feed</a>
                <a class="button-secondary" href="{{ path('app_dashboard') }}">Back to dashboard</a>
            </div>
        </section>

        <section class="social-overview-grid">
            <article class="social-overview-card">
                <small>Total posts</small>
                <strong>{{ overview.posts }}</strong>
                <span>Your published posts</span>
            </article>
            <article class="social-overview-card">
                <small>Total likes</small>
                <strong>{{ overview.likes }}</strong>
                <span>Likes across all your posts</span>
            </article>
            <article class="social-overview-card">
                <small>Total dislikes</small>
                <strong>{{ overview.dislikes }}</strong>
                <span>Dislikes across all your posts</span>
            </article>
            <article class="social-overview-card">
                <small>Total shares</small>
                <strong>{{ overview.shares }}</strong>
                <span>Shares across all your posts</span>
            </article>
            <article class="social-overview-card">
                <small>Total comments</small>
                <strong>{{ overview.comments }}</strong>
                <span>Comments received across all your posts</span>
            </article>
        </section>

        <section class="social-panel">
            <div class="social-panel__head">
                <div>
                    <p class="social-kicker">Last 7 days</p>
                    <h2>Engagement analytics</h2>
                </div>
            </div>

            <div class="social-chart-grid">
                <article class="social-chart-card">
                    <div class="social-chart-card__head">
                        <h3>Daily engagement</h3>
                        <p>Likes, dislikes, and shares across the last seven days.</p>
                    </div>
                    <div class="social-chart-card__canvas" id="social_daily_engagement_chart"></div>
                </article>

                <article class="social-chart-card">
                    <div class="social-chart-card__head">
                        <h3>Engagement split</h3>
                        <p>Overall breakdown of interactions generated by your posts.</p>
                    </div>
                    <div class="social-chart-card__canvas" id="social_engagement_breakdown_chart"></div>
                </article>
            </div>

            <div class="social-management-table-wrap">
                <table class="social-management-table">
                    <thead>
                        <tr>
                            <th>Day</th>
                            <th>Likes</th>
                            <th>Dislikes</th>
                            <th>Shares</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for stat in dailyStats %}
                            <tr>
                                <td>{{ stat.label }}</td>
                                <td>{{ stat.likes }}</td>
                                <td>{{ stat.dislikes }}</td>
                                <td>{{ stat.shares }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>

        <section class="social-panel">
            <div class="social-panel__head">
                <div>
                    <p class="social-kicker">Your content</p>
                    <h2>My posts</h2>
                </div>
            </div>

            <div class="social-post-list">
                {% for post in posts %}
                    <article class="social-post-card social-post-card--management">
                        <div class="social-post-card__header">
                            <div class="social-post-card__author-meta">
                                <h3>{{ post.caption ?: 'Untitled post' }}</h3>
                                <div class="social-post-card__subline">
                                    <span>{{ post.createdAt ? post.createdAt|date('d M Y H:i') : 'No date' }}</span>
                                    <span class="social-dot"></span>
                                    <span>{{ post.visibility }}</span>
                                    <span class="social-dot"></span>
                                    <span>{{ post.status }}</span>
                                </div>
                            </div>
                            <div class="social-inline-actions">
                                <a class="button-secondary" href="{{ path('post_show', {id: post.id}) }}">Open</a>
                                <a class="button-secondary" href="{{ path('post_edit', {id: post.id}) }}">Edit</a>
                            </div>
                        </div>
                        <div class="social-management-stats">
                            <article>
                                <small>Likes</small>
                                <strong>{{ post.likesCount }}</strong>
                            </article>
                            <article>
                                <small>Dislikes</small>
                                <strong>{{ post.dislikesCount }}</strong>
                            </article>
                            <article>
                                <small>Shares</small>
                                <strong>{{ post.sharesCount }}</strong>
                            </article>
                            <article>
                                <small>Comments</small>
                                <strong>{{ post.commentsCount }}</strong>
                            </article>
                        </div>
                    </article>
                {% else %}
                    <div class="empty-state empty-state--large">
                        <h3>No posts yet</h3>
                        <p>Create your first post to start tracking social engagement here.</p>
                    </div>
                {% endfor %}
            </div>
        </section>
    </div>
{% endblock %}
