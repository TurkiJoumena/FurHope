{% extends 'base.html.twig' %}

{% block title %}Ajouter un créneau - Vétérinaire{% endblock %}

{% block body %}
    <div class="layout">
        <div class="shell">
            <div class="auth-wrap">
                <div style="text-align: center; margin-bottom: 32px;">
                    <h1 style="font-size: 2.2rem; margin-bottom: 8px;">{{ form.vars.data.id ? 'Modifier la disponibilité' : 'Ajouter un créneau' }}</h1>
                    <p style="color: var(--muted); margin: 0;">Indiquez vos horaires d'ouverture à la réservation</p>
                </div>

                {% for message in app.flashes('success') %}
                    <div class="flash flash-success" style="margin-bottom: 20px;">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('danger') %}
                    <div class="flash flash-error" style="margin-bottom: 20px;">{{ message }}</div>
                {% endfor %}

                <div class="auth-card form-card">
                    {{ form_start(form, {'attr': {'class': 'auth-form'}}) }}
                        
                        <div class="form-group">
                            {{ form_label(form.date) }}
                            {{ form_widget(form.date) }}
                            <div class="field-error {% if not form.date.vars.valid %}is-visible{% endif %}">{{ form_errors(form.date) }}</div>
                        </div>

                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                            <div class="form-group">
                                {{ form_label(form.startTime) }}
                                {{ form_widget(form.startTime) }}
                                <div class="field-error {% if not form.startTime.vars.valid %}is-visible{% endif %}">{{ form_errors(form.startTime) }}</div>
                            </div>

                            <div class="form-group">
                                {{ form_label(form.endTime) }}
                                {{ form_widget(form.endTime) }}
                                <div class="field-error {% if not form.endTime.vars.valid %}is-visible{% endif %}">{{ form_errors(form.endTime) }}</div>
                            </div>
                        </div>

                        <div class="form-group" style="display: flex; align-items: center; gap: 10px; margin-bottom: 12px; margin-top: 8px;">
                            {{ form_widget(form.isAvailable, {'attr': {'style': 'width: 20px; height: 20px; margin: 0; padding: 0;'}}) }}
                            <div style="margin: 0; font-weight: 700; color: var(--ink);">{{ form_label(form.isAvailable, 'Disponible à la réservation') }}</div>
                        </div>

                        <div class="field-error {% if not form.vars.valid %}is-visible{% endif %}">{{ form_errors(form) }}</div>

                        {{ form_widget(form.save, {'attr': {'class': 'button button-primary'}}) }}
                        
                        <div style="text-align: center; margin-top: 12px;">
                            <a href="{{ path('vet_dispos') }}" style="color: var(--muted); font-weight: 600; font-size: 0.95rem; text-decoration: underline;">Retour aux disponibilités</a>
                        </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
